<!-- app/views/places/show.html.erb -->

<h1><%= @place.name %></h1>

<!-- Button to create a new entry -->
<%= link_to "Add New Entry", new_place_entry_path(@place), class: "btn btn-primary", style: "margin-bottom: 20px;" %>

<h2>Entries</h2>

<% if @entries.present? %>
  <% @entries.each do |entry| %>
    <div style="border: 1px solid #ccc; padding: 10px; margin-bottom: 10px; border-radius: 5px;">
      <h3><%= entry.title %></h3>
      <p><strong>Description:</strong> <%= entry.description %></p>
      <p><strong>Date Visited:</strong> <%= entry.occurred_on %></p>
    </div>
  <% end %>
<% else %>
  <p>No entries yet for this place. Click "Add New Entry" to log your first visit!</p>
<% end %>

<!-- Back link -->
<%= link_to "Back to All Places", root_path, style: "display: inline-block; margin-top: 20px;" %>